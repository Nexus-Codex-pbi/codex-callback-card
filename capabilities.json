{
  "dataRoles": [
    {
      "name": "category",
      "displayName": "Panel label",
      "description": "Category label for each comparison panel",
      "kind": "Grouping"
    },
    {
      "name": "rate",
      "displayName": "Headline value",
      "description": "Primary metric displayed prominently in each panel",
      "kind": "Measure"
    },
    {
      "name": "callbackCount",
      "displayName": "Metric 1",
      "description": "First supporting metric per panel",
      "kind": "Measure"
    },
    {
      "name": "totalCount",
      "displayName": "Metric 2",
      "description": "Second supporting metric per panel",
      "kind": "Measure"
    },
    {
      "name": "lostCount",
      "displayName": "Metric 3",
      "description": "Third supporting metric per panel",
      "kind": "Measure"
    },
    {
      "name": "lostRevenue",
      "displayName": "Highlight value",
      "description": "Highlighted metric displayed in accent colour per panel",
      "kind": "Measure"
    },
    {
      "name": "sortOrder",
      "displayName": "Sort Order",
      "description": "Numeric value to control panel display order (ascending)",
      "kind": "Measure"
    }
  ],
  "dataViewMappings": [
    {
      "categorical": {
        "categories": {
          "select": [
            {
              "for": {
                "in": "category"
              }
            }
          ],
          "dataReductionAlgorithm": {
            "top": {
              "count": 30000
            }
          }
        },
        "values": {
          "select": [
            {
              "for": {
                "in": "rate"
              }
            },
            {
              "for": {
                "in": "callbackCount"
              }
            },
            {
              "for": {
                "in": "totalCount"
              }
            },
            {
              "for": {
                "in": "lostCount"
              }
            },
            {
              "for": {
                "in": "lostRevenue"
              }
            },
            {
              "for": {
                "in": "sortOrder"
              }
            }
          ]
        }
      }
    }
  ],
  "objects": {
