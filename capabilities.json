      "description": "Third supporting metric per panel",
      "kind": "Measure"
    },
    {
      "name": "lostRevenue",
      "displayName": "Highlight value",
      "description": "Highlighted metric displayed in accent colour per panel",
      "kind": "Measure"
    },
    {
      "name": "sortOrder",
      "displayName": "Sort Order",
      "description": "Numeric value to control panel display order (ascending)",
      "kind": "Measure"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "category": {
            "max": 1
          },
          "rate": {
            "max": 1
          },
          "callbackCount": {
            "max": 1
          },
          "totalCount": {
            "max": 1
          },
          "lostCount": {
            "max": 1
          },
          "lostRevenue": {
            "max": 1
          },
          "sortOrder": {
            "max": 1
          }
        }
      ],
      "categorical": {
        "categories": {
          "for": {
            "in": "category"
          },
          "dataReductionAlgorithm": {
            "top": {
              "count": 30000
            }
          }
        },
        "values": {
          "select": [
            {
              "for": {
                "in": "rate"
              }
            },
            {
              "for": {
                "in": "callbackCount"
              }
            },
            {
              "for": {
                "in": "totalCount"
              }
            },
            {
              "for": {
                "in": "lostCount"
              }
            },
            {
              "for": {
                "in": "lostRevenue"
              }
            },
            {
              "for": {
                "in": "sortOrder"
              }
            }
          ]
        }
      }
    }
  ],
